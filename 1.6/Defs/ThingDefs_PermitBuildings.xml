  <ThingDef ParentName="BuildingBase">
    <defName>HVMP_Mortar</defName>
    <label>pax mortar</label>
    <description>A self-powered, self-loading, automatic mortar. It can hit targets at any distance, over walls, but is quite inaccurate. Self-destructs after 2 days.</description>
    <thingClass>Building_TurretGun</thingClass>
    <drawerType>MapMeshAndRealTime</drawerType>
    <graphicData>
      <texPath>Things/Building/Mech/TurretMechLarge_Base</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(2,2)</drawSize>
      <drawOffset>(0,0,-0.16)</drawOffset>
      <damageData>
        <rect>(0.3,0.3,1.4,1.4)</rect>
      </damageData>
      <shadowData>
        <offset>(-0.13,-0.87,-0.1)</offset>
        <volume>(0.5,0.4,1.05)</volume>
      </shadowData>
    </graphicData>
    <receivesSignals>true</receivesSignals>
    <altitudeLayer>Building</altitudeLayer>
    <stealable>false</stealable>
    <size>(2,2)</size>
    <passability>PassThroughOnly</passability>
    <pathCost>50</pathCost>
    <fillPercent>0.4</fillPercent>
