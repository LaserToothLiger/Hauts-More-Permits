<Patch>
	<!--Branch Standing Value subs out for Royal Favor Value while you're trading with an e-branch-->
	<Operation Class="PatchOperationConditional">
		<xpath>/Defs/StatDef[defName="RoyalFavorValue"]/parts</xpath>
		<nomatch Class="PatchOperationAdd">
			<xpath>/Defs/StatDef[defName="RoyalFavorValue"]</xpath>
			<value>
				<parts>
				  <li Class="HautsPermits.StatPart_BranchStanding" />
				</parts>
			</value>
		</nomatch>
		<match Class="PatchOperationAdd">
			<xpath>/Defs/StatDef[defName="RoyalFavorValue"]/parts</xpath>
			<value>
			  <li Class="HautsPermits.StatPart_BranchStanding" />
			</value>
		</match>
	</Operation>
	
