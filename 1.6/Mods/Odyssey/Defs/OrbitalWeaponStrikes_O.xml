  <ThingDef ParentName="OrbitalStrikeBase">
    <defName>HVMP_OT_HunterDrone</defName>
    <label>orbital hunter drone</label>
    <thingClass>HVMP_Odyssey.DroneDeployer</thingClass>
    <comps>
      <li Class="CompProperties_OrbitalBeam">
        <width>0.2</width>
        <color>(210, 210, 255, 242)</color>
      </li>
      <li Class="HVMP_Odyssey.CompProperties_DroneDeployer">
		<warmupTicks>240</warmupTicks>
        <pawnCount>1</pawnCount>
		<pawnOptions>
		  <li>Drone_Hunter</li>
		</pawnOptions>
		<overrideFaction>AncientsHostile</overrideFaction>
      </li>
    </comps>
  </ThingDef>
  
