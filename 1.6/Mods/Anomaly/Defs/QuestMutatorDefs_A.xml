    <label>blood blight</label>
    <description>A foul psychic emanation causes random living creatures to develop blood rot.</description>
  </GameConditionDef>
  <GameConditionDef>
    <defName>HVMP_TOTU_EldritchViscosity</defName>
    <conditionClass>HautsPermits_Occult.GameCondition_InflictHediff_Lovecraft</conditionClass>
    <label>psychic viscosity</label>
    <description>Powerful psychic currents pull at the motor nervous systems of living creatures, slowing them down as if moving in molasses.</description>
	<modExtensions>
		<li Class="HautsFramework.InflictedHediff"><hediff>HVMP_TOTU_PsychicViscosity</hediff></li>
	</modExtensions>
  </GameConditionDef>
	  <HediffDef ParentName="DiseaseBase">
		<defName>HVMP_TOTU_PsychicViscosity</defName>
		<label>psychic viscosity</label>
		<description>Powerful psychic currents pull at the motor nervous systems of this creature, slowing it down as if moving in molasses.</description>
		<isBad>true</isBad>
		<everCurableByItem>false</everCurableByItem>
		<comps>
		  <li Class="HautsFramework.HediffCompProperties_ReliantOnGameCondition">
			<gameCondition>HVMP_TOTU_EldritchViscosity</gameCondition>
			<dontAffectAnomalies>true</dontAffectAnomalies>
			<dontAffectMechs>true</dontAffectMechs>
		  </li>
		</comps>
		<stages>
		  <li>
			<capMods>
			  <li>
				<capacity>Moving</capacity>
				<setMaxCurveOverride>
				  <points>
					<li>0, 1</li>
					<li>1, 0.5</li>
				  </points>
				</setMaxCurveOverride>
				<setMaxCurveEvaluateStat>PsychicSensitivity</setMaxCurveEvaluateStat>
			  </li>
			</capMods>
		  </li>
		</stages>
	  </HediffDef>
