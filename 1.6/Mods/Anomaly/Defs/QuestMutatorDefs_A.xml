    <defName>HVMP_AOEAH_thought</defName>
    <workerClass>ThoughtWorker_Hediff</workerClass>
    <thoughtClass>HautsPermits_Occult.Thought_AOEAH</thoughtClass>
    <hediff>HVMP_AOEAH_hediff</hediff>
