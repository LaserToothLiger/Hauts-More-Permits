  <GameConditionDef>
    <defName>HVMP_AOEAH</defName>
    <conditionClass>HautsPermits_Occult.GameCondition_InflictHediff_Lovecraft</conditionClass>
    <label>psychic upset</label>
    <description>An otherworldly engine of psychic antipathy eats at the restfulness of everyone in the labyrinth, and causes their mood to worsen progressively.</description>
    <letterText>Within the anomaly's confines, psychic antipathy eats away at wakefulness and mood.</letterText>
    <letterDef>NegativeEvent</letterDef>
    <canBePermanent>true</canBePermanent>
	<modExtensions>
		<li Class="HautsFramework.InflictedHediff"><hediff>HVMP_AOEAH_hediff</hediff></li>
	</modExtensions>
  </GameConditionDef>
	  <HediffDef ParentName="DiseaseBase">
		<defName>HVMP_AOEAH_hediff</defName>
		<label>psychic upset</label>
		<description>An otherworldly engine of psychic antipathy eats at the restfulness of everyone in the labyrinth, and causes their mood to worsen progressively.</description>
		<isBad>false</isBad>
		<minSeverity>1</minSeverity>
		<initialSeverity>1</initialSeverity>
		<maxSeverity>66.6</maxSeverity>
		<comps>
		  <li Class="HautsFramework.HediffCompProperties_ReliantOnGameCondition">
			<gameCondition>HVMP_AOEAH</gameCondition>
			<dontAffectAnomalies>true</dontAffectAnomalies>
			<dontAffectMechs>true</dontAffectMechs>
		  </li>
		  <li Class="HediffCompProperties_SeverityPerDay">
			<severityPerDay>24</severityPerDay>
		  </li>
		</comps>
		<stages>
		  <li>
			<statOffsets>
			  <RestFallRateFactor>0.5</RestFallRateFactor>
			</statOffsets>
		  </li>
		</stages>
	  </HediffDef>
