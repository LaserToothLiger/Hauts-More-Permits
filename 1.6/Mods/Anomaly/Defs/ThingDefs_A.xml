<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  
  <!--permits-->
  <ThingDef ParentName="HVMP_PalletBase">
    <defName>HVMP_SerumPallet</defName>
    <label>serum pallet</label>
    <description>A crate containing two serums. You can choose what type of serum is inside by opening it.</description>
    <graphicData>
      <texPath>Items/Pallets/HVMP_SerumPallet</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <comps>
      <li Class="HautsPermits.CompProperties_UseEffect_MultipleChoicePallet">
        <allowedTradeTag>Serum</allowedTradeTag>
		<maxNumOptions>25</maxNumOptions>
		<netCountOutputCap>2</netCountOutputCap>
		<countCantExceedStackSize>true</countCantExceedStackSize>
      </li>
    </comps>
  </ThingDef>
  <ThingDef ParentName="TorchBase">
    <defName>HVMP_Voidcairn</defName>
    <label>voidcairn</label>
    <description>A ritualistic device which incorporates dense wafers of crystalline eltex circuitry to alter currents in the psychic manifold. When placed near a psychic ritual spot, it improves the ritual quality; it also increases the containment strength of holding facilities in its radius.\n\nA ritual or holding facility can benefit from up to four voidcairns.</description>
    <graphicData>
      <texPath>Things/Building/HVMP_Voidcairn</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1.2</drawSize>
    </graphicData>
    <minifiedDef>MinifiedThing</minifiedDef>
    <thingCategories>
      <li>BuildingsMisc</li>
    </thingCategories>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <Mass>10</Mass>
    </statBases>
    <costList Inherit="False">
      <ComponentIndustrial>1</ComponentIndustrial>
      <Steel>25</Steel>
	  <VPE_Eltex MayRequire="VanillaExpanded.VPsycastsE">1</VPE_Eltex>
    </costList>
    <placeWorkers>
      <li>PlaceWorker_ShowFacilitiesConnections</li>
      <li>PlaceWorker_ShowFacilitiesRange</li>
    </placeWorkers>
    <drawPlaceWorkersWhileSelected>false</drawPlaceWorkersWhileSelected>
    <building>
      <buildingTags>
        <li>Anomaly</li>
      </buildingTags>
    </building>
    <leaveResourcesWhenKilled>true</leaveResourcesWhenKilled>
    <resourcesFractionWhenDeconstructed>1</resourcesFractionWhenDeconstructed>
    <comps Inherit="False">
      <li Class="CompProperties_Facility">
        <compClass>HautsPermits_Occult.CompVoidcairn</compClass>
		<statOffsets>
          <PsychicRitualQuality>0.08</PsychicRitualQuality>
          <ContainmentStrength>10</ContainmentStrength>
        </statOffsets>
        <maxSimultaneous>4</maxSimultaneous>
        <maxDistance>10</maxDistance>
      </li>
      <li Class="CompProperties_Glower">
        <glowRadius>2.1</glowRadius>
        <glowColor>(120,255,214,1)</glowColor>
      </li>
    </comps>
  </ThingDef>
  <ThingDef ParentName="BuildingBase">
    <defName>HVMP_HelldrillLandmine</defName>
    <label>Helldrill landmine</label>
    <description>A fragment of dark archotechnology embedded into a bioferrite-based shaped explosive. Once triggered, it will repeatedly immolate the surrounding area. Most of the explosion's force will be directed downward to bore a shaft to the deeps, and fleshbeasts attracted by the detonation's psychic shockwave will emerge from this shaft.</description>
    <thingClass>HautsPermits_Occult.Building_TrapHelldrill</thingClass>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Things/Building/HVMP_HelldrillCharge</texPath>
      <drawSize>1.1</drawSize>
    </graphicData>
    <minifiedDef>MinifiedThing</minifiedDef>
    <statBases>
      <MaxHitPoints>1400</MaxHitPoints>
      <Mass>7.7</Mass>
    </statBases>
    <thingCategories>
      <li>Buildings</li>
    </thingCategories>
	<tickerType>Normal</tickerType>
    <costList>
      <Bioferrite>80</Bioferrite>
    </costList>
    <damageMultipliers>
      <li>
        <damageDef>Vaporize</damageDef>
        <multiplier>0.25</multiplier>
      </li>
    </damageMultipliers>
    <comps>
      <li Class="HautsPermits_Occult.CompProperties_Helldrill">
		<detonationPeriodicity>240</detonationPeriodicity>
		<explosiveRadius>7.9</explosiveRadius>
        <explosiveDamageType>Vaporize</explosiveDamageType>
		<chanceToStartFire>0.75</chanceToStartFire>
		<damageFalloff>true</damageFalloff>
		<fleshbeastThreatPointFactor>0.25</fleshbeastThreatPointFactor>
		<!--<explosionSound>Explosion_Vaporize</explosionSound>-->
      </li>
    </comps>
    <specialDisplayRadius>7.9</specialDisplayRadius>
  </ThingDef>
  
</Defs>